def retry_call(attempts: int = 3):
    """Retry decorator"""

    def decorator(func: Callable):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):

            for i in range(1, attempts + 1):
                try:
                    return func(*args, **kwargs)

                except Exception as e:
                    print(f"[WARNING] Retry {i}/{attempts} failed:", e)

                    if i == attempts:
                        raise

                    time.sleep(1)

        return wrapper

    return decorator

def timed(func: Callable):
    """Timer decorator"""

    @functools.wraps(func)
    def wrapper(*args, **kwargs):

        start = time.perf_counter()

        result = func(*args, **kwargs)

        end = time.perf_counter()

        print(f"[INFO] {func.__name__} executed in {end-start:.4f} seconds")

        return result

    return wrapper

class MemoryCache:
    """Simple cache decorator"""

    def __init__(self, expire: int = 60):
        self.expire = expire
        self.cache: Dict[Any, tuple] = {}

    def __call__(self, func: Callable):

        @functools.wraps(func)
        def wrapper(*args, **kwargs):

            key = (args, tuple(kwargs.items()))
            current = time.time()

            if key in self.cache:
                value, timestamp = self.cache[key]

                if current - timestamp < self.expire:
                    print("[DEBUG] Cache hit")
                    return value

            result = func(*args, **kwargs)

            self.cache[key] = (result, current)

            return result

        return wrapper

class StreamProcessor:
    """Generator-based data pipeline"""

    def __init__(self):
        self.steps = []

    def step(self, func: Callable):
        self.steps.append(func)
        return self

    def process(self, filepath: str) -> Iterator[dict]:

        path = Path(filepath)

        with open(path, "r") as file:

            for line in file:

                data = json.loads(line)

                for step in self.steps:
                    data = step(data)

                yield data

def chunk_iterator(data: Iterator, size: int = 1000):
    """Batch generator"""

    batch = []

    for item in data:

        batch.append(item)

        if len(batch) == size:
            yield batch
            batch = []

    if batch:
        yield batch

